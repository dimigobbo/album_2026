# Copie este arquivo para ".env.local" e preencha com os dados do seu
# projeto Firebase (Configurações do projeto > Geral > "Seus apps" > Web app).
# Todas começam com NEXT_PUBLIC_ porque o Firebase client SDK roda no navegador.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
